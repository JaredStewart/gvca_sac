# OpenAI API Key for LLM tagging
OPENAI_API_KEY=sk-your-key-here

# PocketBase URL (for local development)
POCKETBASE_URL=http://localhost:8090

# API URL (for frontend)
VITE_API_URL=http://localhost:8000
